      <!-- ==================== 场景2：多意图功能测试 ==================== -->
      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup" testname="场景2：多意图功能测试" enabled="true">
        <stringProp name="ThreadGroup.on_sample_error">continue</stringProp>
